# GPU support — NOT IMPLEMENTED, see W0 decisions (docs/adr/002-rewrite-plan.md §10 Q2)
#
# This file is a stub. CPU is the chosen starting point per W0. When GPU is
# actually needed, finish this Dockerfile and wire it into docker-compose via a
# build arg / target. Until then DO NOT docker build this file in CI.

ARG CUDA_VERSION=12.4.0
ARG PYTHON_VERSION=3.12
ARG WHISPERX_DEVICE=cuda

FROM nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu22.04

# TODO(A3 follow-up — GPU): implement when GPU hardware decision is made.
