#        pip install --index-url https://download.pytorch.org/whl/cu124 \
#            torch torchaudio
#   3. install whisperx + fastapi stack (same as CPU Dockerfile)
#   4. copy server.py, set ENV WHISPER_DEVICE=cuda,
#      WHISPER_COMPUTE_TYPE=float16, MODEL_CACHE_DIR=/models
#   5. CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "7860"]
#
# Open questions to resolve before implementing:
#   - nvidia-container-toolkit available in target environment?
#   - which CUDA minor version matches the driver on the host?
#   - is the model volume shared with the CPU image? (yes — same /models layout)

CMD ["echo", "whisperx-svc GPU image is not implemented yet — see Dockerfile.gpu TODO"]
